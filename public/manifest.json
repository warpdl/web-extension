{
    "manifest_version": 3,
    "name": "WarpDL",
    "version": "0.2",
    "description": "Warp is a powerful and versatile cross-platform download manager.",
    "background": {
        "service_worker": "service_worker.js"
    },
    "action": {
        "default_popup": "popup.html"
    },
    "permissions": [
        "downloads",
        "cookies",
        "webRequest",
        "storage",
        "activeTab"
    ],
    "host_permissions": [
        "https://*/*",
        "http://*/*"
    ],
    "content_scripts": [
        {
            "matches": ["*://*.youtube.com/*"],
            "js": ["youtube_main_world.js"],
            "world": "MAIN",
            "run_at": "document_start"
        },
        {
            "matches": ["*://*.youtube.com/*"],
            "js": ["youtube_content.js"],
            "run_at": "document_idle"
        },
        {
            "matches": ["<all_urls>"],
            "exclude_matches": ["*://*.youtube.com/*"],
            "js": ["content_script.js"],
            "run_at": "document_idle"
        }
    ]
}
